msgstr "Xuất sang tệp HTML cùng với tệp TreeSheets gốc khi tài liệu được lưu"

msgid ""
"Export to a HTML file with exported images alongside the original TreeSheets "
"file when document is saved"
msgstr "Xuất sang tệp HTML kèm theo các hình ảnh đã xuất cùng với tệp TreeSheets gốc khi tài liệu được lưu"

